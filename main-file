# =============================================================================
#  SECTION 2: TEXT PREPROCESSING
# =============================================================================
#
#  Neural networks can only work with numbers, never raw text.
#  This section converts raw player sentences into clean integer sequences.
#
#  Steps:
#   1. Tokenize: Split sentence into individual word tokens
#   2. Build Vocabulary: Assign a unique integer ID to every known word
#   3. Encode: Replace each word with its integer ID
#   4. Pad: Make all sequences the same length (required for batching)

def tokenize(text: str) -> list:
    """
    Converts a raw string into a list of lowercase word tokens.
    The regex removes everything that isn't a letter or number.

    Example:
        "Are you trying to rob me blind?"
        → ["are", "you", "trying", "to", "rob", "me", "blind"]
    """
    text = text.lower()
    text = re.sub(r"[^a-z0-9\s]", "", text)   # strip punctuation
    return text.split()


class Vocabulary:
    """
    A lookup table that maps words <-> integers.

    Special tokens:
      <PAD> (index 0) — used to fill short sequences to a fixed length
      <UNK> (index 1) — used for words never seen during training
    """

    PAD_TOKEN = "<PAD>"   # Padding token  → index 0
    UNK_TOKEN = "<UNK>"   # Unknown token  → index 1

    def __init__(self):
        self.word2idx = {self.PAD_TOKEN: 0, self.UNK_TOKEN: 1}
        self.idx2word = {0: self.PAD_TOKEN, 1: self.UNK_TOKEN}
        self.word_counts = Counter()

    def build(self, sentences: list, min_freq: int = 1):
        """
        Scans all tokenized sentences and adds every word that appears
        at least `min_freq` times into the vocabulary.

        min_freq=1 means every single word gets a slot (good for small datasets).
        In a production game with millions of texts, you'd use min_freq=2 or 3
        to ignore rare typos and noise.
        """
        for tokens in sentences:
            self.word_counts.update(tokens)

        for word, count in self.word_counts.items():
            if count >= min_freq and word not in self.word2idx:
                idx = len(self.word2idx)
                self.word2idx[word] = idx
                self.idx2word[idx] = word

        print(f"[Vocabulary] Built. Size: {len(self.word2idx)} tokens "
              f"(including <PAD> and <UNK>)")

    def encode(self, tokens: list) -> list:
        """Converts a list of word strings to a list of integer IDs."""
        return [self.word2idx.get(t, self.word2idx[self.UNK_TOKEN])
                for t in tokens]

    def __len__(self):
        return len(self.word2idx)


def pad_sequence(ids: list, max_len: int, pad_idx: int = 0) -> list:
    """
    Makes every sequence exactly `max_len` long.

    Too SHORT → pad with pad_idx (0) on the RIGHT
    Too LONG  → truncate from the RIGHT (keep the first max_len words)

    Example (max_len=10):
      [4, 12, 88, 3, 201, 17, 55]  →  [4, 12, 88, 3, 201, 17, 55, 0, 0, 0]
    """
    if len(ids) < max_len:
        ids = ids + [pad_idx] * (max_len - len(ids))
    else:
        ids = ids[:max_len]
    return ids


# =============================================================================
#  SECTION 3: PYTORCH DATASET
# =============================================================================
#
#  PyTorch uses a Dataset + DataLoader pattern:
#   Dataset    — knows HOW to get one (X, y) sample
#   DataLoader — automatically batches, shuffles, and feeds samples to the model

class IntentDataset(Dataset):
    """
    Wraps our raw training data into PyTorch tensors.

    Each item is a tuple: (encoded_sentence_tensor, label_tensor)
    """

    def __init__(self, raw_data: list, vocab: Vocabulary, max_len: int):
        self.samples = []
        for text, intent_str in raw_data:
            tokens  = tokenize(text)
            ids     = vocab.encode(tokens)
            padded  = pad_sequence(ids, max_len)
            label   = INTENT_LABELS[intent_str]

            self.samples.append((
                torch.tensor(padded, dtype=torch.long),   # input  (sequence of IDs)
                torch.tensor(label,  dtype=torch.long),   # target (class index)
            ))

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        return self.samples[idx]


# =============================================================================
#  SECTION 4: THE NEURAL NETWORK ARCHITECTURE
# =============================================================================
#
#  Our model has four layers stacked like a pipeline:
#
#  LAYER 1 — nn.Embedding (The "Dictionary")
#  ─────────────────────────────────────────
#  Think of this as a giant dictionary. You give it an integer (word ID)
#  and it hands back a small float vector (the word's "meaning").
#  • vocab_size × embedding_dim lookup table (e.g., 350 × 64)
#  • Input shape:  (batch, seq_len)
#  • Output shape: (batch, seq_len, embedding_dim)
#  The weights in this table are LEARNED — they start random and are
#  adjusted every training step so words with similar uses get similar vectors.
#
#  LAYER 2 — nn.LSTM (The "Memory Reader")
#  ──────────────────────────────────────────
#  LSTM = Long Short-Term Memory. It reads the word vectors ONE AT A
#  TIME, left to right, maintaining a "memory state" as it goes.
#  After reading "Are you trying to rob me blind", the LSTM produces
#  a single hidden vector that summarises the WHOLE sentence.
#  • Input:  (batch, seq_len, embedding_dim)
#  • Output: hidden state of shape (batch, hidden_dim)
#  We use bidirectional=True so the LSTM reads forwards AND backwards.
#  This is like reading a sentence normally and then in reverse —
#  the model gets double the context.
#
#  LAYER 3 — nn.Linear + ReLU (The "Interpreter")
#  ─────────────────────────────────────────────────
#  A standard fully-connected layer that transforms the LSTM's output
#  into a higher-level representation. ReLU activation keeps values
#  non-negative.
#
#  LAYER 4 — nn.Linear (The "Decision Maker")
#  ────────────────────────────────────────────
#  The final layer outputs exactly 5 raw scores (one per intent).
#  The intent with the HIGHEST score wins.

class MagicVendorIntentClassifier(nn.Module):

    def __init__(self,
                 vocab_size:    int,
                 embedding_dim: int,
                 hidden_dim:    int,
                 output_dim:    int,
                 pad_idx:       int,
                 dropout_rate:  float = 0.4):
        """
        Args:
            vocab_size    : Total number of unique words in our vocabulary
            embedding_dim : How many floats represent each word (64)
            hidden_dim    : Internal size of the LSTM memory (128 is solid)
            output_dim    : Number of intents to classify into (5)
            pad_idx       : The <PAD> token ID — its embedding stays all zeros
            dropout_rate  : Fraction of neurons randomly disabled during
                            training to prevent overfitting (memorising data)
        """
        super().__init__()

        # ── Layer 1: Embedding ────────────────────────────────────────────
        # padding_idx tells PyTorch that token 0 (<PAD>) carries no meaning.
        # Its embedding vector is forced to stay all zeros and is not trained.
        self.embedding = nn.Embedding(
            num_embeddings = vocab_size,
            embedding_dim  = embedding_dim,
            padding_idx    = pad_idx,
        )

        # ── Layer 2: Bidirectional LSTM ───────────────────────────────────
        # batch_first=True means input shape is (batch, seq, features)
        # which is more intuitive than PyTorch's default (seq, batch, features)
        self.lstm = nn.LSTM(
            input_size    = embedding_dim,
            hidden_size   = hidden_dim,
            num_layers    = 2,            # Stack two LSTMs for deeper reasoning
            bidirectional = True,         # Read forwards AND backwards
            batch_first   = True,
            dropout        = dropout_rate if 2 > 1 else 0.0,
        )

        # ── Dropout (Regularisation) ──────────────────────────────────────
        # Randomly zeroes out neurons during training only.
        # Forces the network to learn ROBUST features rather than memorising.
        self.dropout = nn.Dropout(dropout_rate)

        # ── Layer 3: Intermediate FC ──────────────────────────────────────
        # Bidirectional LSTM doubles the hidden size (forwards + backwards)
        self.fc1 = nn.Linear(hidden_dim * 2, hidden_dim)
        self.relu = nn.ReLU()

        # ── Layer 4: Output FC ────────────────────────────────────────────
        self.fc2 = nn.Linear(hidden_dim, output_dim)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        The forward pass — the path data takes through the network.

        Args:
            x: Integer tensor of shape (batch_size, seq_len)
               e.g., [[4, 12, 88, 3, 201, 17, 55, 0, 0, 0], ...]

        Returns:
            logits: Raw score tensor of shape (batch_size, num_intents)
                    e.g., [[-1.2, 0.3, 3.8, 0.1, -0.7]] → haggle wins!
        """
        # Step 1: Convert integer IDs → float vectors
        # Shape: (batch, seq_len) → (batch, seq_len, embedding_dim)
        embedded = self.dropout(self.embedding(x))

        # Step 2: Feed the sequence through the LSTM
        # lstm_out shape: (batch, seq_len, hidden_dim * 2)  [bidirectional]
        # hidden shape:   (num_layers * 2, batch, hidden_dim)
        lstm_out, (hidden, _) = self.lstm(embedded)

        # Step 3: Extract the final meaningful hidden state
        # We take the last layer's forward and backward hidden states
        # and concatenate them into one vector per sentence.
        # hidden[-2] = last layer's forward direction
        # hidden[-1] = last layer's backward direction
        final_hidden = torch.cat((hidden[-2], hidden[-1]), dim=1)
        # Shape: (batch, hidden_dim * 2)

        # Step 4: Apply dropout for regularisation
        dropped = self.dropout(final_hidden)

        # Step 5: Pass through FC layers for final classification
        out = self.relu(self.fc1(dropped))
        logits = self.fc2(out)
        # Shape: (batch, output_dim=5)

        return logits


# =============================================================================
#  SECTION 5: TRAINING LOOP
# =============================================================================
#
#  Training is the process of showing the model examples, seeing how wrong
#  its guesses are, and nudging the weights slightly in the right direction.
#
#  KEY CONCEPTS:
#   Loss Function (CrossEntropyLoss): Measures how wrong the model is.
#     Lower = better. We want to minimise this.
#
#   Optimiser (Adam): The algorithm that decides HOW to nudge the weights.
#     Adam is the industry standard — fast, adaptive, reliable.
#
#   Epoch: One complete pass through all training data.
#     We do many epochs, each time the model gets slightly smarter.
#
#   Gradient: The mathematical direction to move each weight to reduce loss.
#     PyTorch computes this automatically via backpropagation.

def train_model(model, dataloader, epochs=200, lr=0.001):
    """
    Full training loop.

    Args:
        model      : The MagicVendorIntentClassifier instance
        dataloader : PyTorch DataLoader wrapping our IntentDataset
        epochs     : How many times to cycle through all training data
        lr         : Learning rate — how big each weight adjustment step is.
                     Too large → overshoots, too small → learns too slowly.

    Returns:
        The trained model.
    """
    # CrossEntropyLoss combines Softmax + NLLLoss — standard for classification.
    # It penalises the model heavily for being confidently wrong.
    criterion = nn.CrossEntropyLoss()

    # Adam optimiser — adaptive learning rate, great default for NLP.
    # weight_decay adds L2 regularisation to prevent overfitting.
    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=1e-4)

    # Learning rate scheduler: halves the LR if loss stops improving.
    # This prevents the model from oscillating around a solution.
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(
        optimizer, mode='min', factor=0.5, patience=15
    )

    model.train()   # Switch model to training mode (enables dropout)

    print("\n" + "="*60)
    print("  TRAINING THE MAGIC VENDOR BRAIN")
    print("="*60)

    for epoch in range(1, epochs + 1):
        total_loss    = 0.0
        correct_preds = 0
        total_samples = 0

        for batch_x, batch_y in dataloader:
            # ── Forward Pass ─────────────────────────────────────────────
            logits = model(batch_x)              # Get raw scores from model
            loss   = criterion(logits, batch_y)  # Measure how wrong they are

            # ── Backward Pass (Backpropagation) ──────────────────────────
            optimizer.zero_grad()   # Clear old gradients (MUST do every step)
            loss.backward()         # Compute new gradients via chain rule

            # Gradient clipping: stops gradients from exploding to infinity
            # This is important for RNNs/LSTMs which can be unstable.
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)

            optimizer.step()        # Apply gradient updates to all weights

            # ── Metrics ──────────────────────────────────────────────────
            total_loss    += loss.item()
            predictions    = torch.argmax(logits, dim=1)  # Pick highest score
            correct_preds += (predictions == batch_y).sum().item()
            total_samples += batch_y.size(0)

        avg_loss = total_loss / len(dataloader)
        accuracy = correct_preds / total_samples * 100
        scheduler.step(avg_loss)

        # Print progress every 10 epochs
        if epoch % 10 == 0 or epoch == 1:
            print(f"  Epoch [{epoch:>3}/{epochs}]  "
                  f"Loss: {avg_loss:.4f}  "
                  f"Accuracy: {accuracy:.1f}%")

    print("="*60)
    print("  Training Complete!")
    print("="*60 + "\n")
    return model


# =============================================================================
#  SECTION 6: INFERENCE — Using the Trained Model
# =============================================================================

def predict_intent(text: str,
                   model,
                   vocab: Vocabulary,
                   max_len: int,
                   top_k: int = 3) -> dict:
    """
    Takes raw player text and returns the predicted intent with confidence.

    Args:
        text    : Raw player input string
        model   : Trained MagicVendorIntentClassifier
        vocab   : Trained Vocabulary
        max_len : Sequence length (must match training)
        top_k   : How many top intents to show in the report

    Returns:
        A dict with 'intent', 'confidence', and 'all_scores'
    """
    model.eval()  # Switch to eval mode: disables dropout for deterministic output

    with torch.no_grad():  # No need to track gradients during inference
        tokens  = tokenize(text)
        ids     = vocab.encode(tokens)
        padded  = pad_sequence(ids, max_len)
        tensor  = torch.tensor([padded], dtype=torch.long)  # Add batch dimension

        logits      = model(tensor)                    # Raw scores
        # Softmax converts raw scores into probabilities that sum to 1.0
        # e.g., [-1.2, 0.3, 3.8, 0.1, -0.7] → [0.02, 0.08, 0.84, 0.04, 0.02]
        probs       = torch.softmax(logits, dim=1)[0]  # Remove batch dimension
        pred_idx    = torch.argmax(probs).item()
        confidence  = probs[pred_idx].item()

        # Build a sorted leaderboard of all intents
        all_scores = {
            LABEL_TO_INTENT[i]: round(probs[i].item(), 4)
            for i in range(len(INTENT_LABELS))
        }
        sorted_scores = dict(
            sorted(all_scores.items(), key=lambda x: x[1], reverse=True)
        )

    return {
        "input":      text,
        "tokens":     tokens,
        "intent":     LABEL_TO_INTENT[pred_idx],
        "confidence": round(confidence * 100, 2),
        "all_scores": sorted_scores,
    }


def print_prediction(result: dict):
    """Pretty-prints an inference result."""
    print("+" + "-"*58 + "+")
    print(f"|  INPUT      : \"{result['input']}\"")
    print(f"|  TOKENS     : {result['tokens']}")
    print(f"|  PREDICTION : {result['intent'].upper()}")
    print(f"|  CONFIDENCE : {result['confidence']}%")
    print("|  ALL SCORES :")
    for intent, score in result["all_scores"].items():
        bar   = "#" * int(score * 30)
        print(f"|    {intent:<18} {score:.4f}  {bar}")
    print("+" + "-"*58 + "+\n")


# =============================================================================
#  SECTION 7: ONNX EXPORT — Packaging the Brain for Unreal Engine
# =============================================================================
#
#  ONNX (Open Neural Network Exchange) is a universal format for ML models.
#  Unreal Engine's NNI (Neural Network Inference) plugin can load .onnx files
#  and run them natively in C++ with zero Python dependency at runtime.
#
#  HOW IT WORKS IN UNREAL ENGINE:
#
#  1. Export this .onnx file (done here in Python, below)
#  2. Add the NNI plugin to your UE project (Plugins → Neural Network Inference)
#  3. In C++, use UNeuralNetwork to load the model:
#
#       UNeuralNetwork* VendorBrain = NewObject<UNeuralNetwork>();
#       VendorBrain->Load(TEXT("/Game/AI/magic_vendor_brain.onnx"));
#
#  4. Preprocess player text in C++ (tokenize, encode, pad) using the
#     exported vocab JSON file, then feed to the model:
#
#       TArray<float> InputData = EncodePlayerText(PlayerInput, VocabTable);
#       VendorBrain->SetInputFromArrayCopy(InputData);
#       VendorBrain->Run();
#       TArray<float> OutputScores = VendorBrain->GetOutputTensor(...);
#
#  5. Argmax the output scores → trigger the correct UE dialogue/UI system.

def export_to_onnx(model,
                   vocab: Vocabulary,
                   max_len: int,
                   path: str = "magic_vendor_brain.onnx"):
    """
    Exports the trained PyTorch model to ONNX format.

    Also exports the vocabulary and configuration as a JSON file so your
    C++ Unreal Engine code can replicate the exact same text preprocessing.

    Args:
        model   : Trained classifier (must be in eval mode)
        vocab   : Trained vocabulary
        max_len : Sequence length used during training
        path    : Output path for the .onnx file
    """
    # ── Dependency guard (auto-install already ran at module load time) ───
    # This secondary check is a safety net for environments where the bootstrap
    # above may not have run (e.g., partial imports). Should never trigger.
    try:
        import onnx  # noqa: F401
    except ImportError:
        raise ImportError(
            "\n[ONNX Export] 'onnx' is still missing after auto-install.\n"
            "  Manual fix: !pip install onnx   (then restart the runtime)\n"
        )

    model.eval()

    # ── Create a dummy input tensor ───────────────────────────────────────
    # ONNX export traces the model's computation graph by running it once
    # with a dummy input of batch_size=1.  We fix batch_size=1 here because:
    #  • Unreal Engine NNI always scores ONE player sentence at a time.
    #  • The LSTM batch-size UserWarning is eliminated — no variable batch.
    dummy_input = torch.zeros(1, max_len, dtype=torch.long)

    # ── Export to ONNX ────────────────────────────────────────────────────
    # dynamo=False  → legacy TorchScript path. Required for:
    #   a) UE NNI opset 11 compatibility
    #   b) Avoiding onnxscript dependency (dynamo=True needs onnxscript too)
    #
    # Removed parameters vs PyTorch < 2.6:
    #   do_constant_folding — DEPRECATED in 2.6, always enabled internally now.
    #   training            — DEPRECATED in 2.6, call model.eval() before export.
    torch.onnx.export(
        model,
        dummy_input,
        path,
        export_params  = True,               # Bake trained weights into the file
        opset_version  = 11,                 # ONNX opset 11 — stable UE NNI target
        input_names    = ["player_input"],   # Tensor name visible in UE NNI C++
        output_names   = ["intent_logits"],  # Tensor name visible in UE NNI C++
        dynamic_axes   = {
            "player_input":  {0: "batch_size"},
            "intent_logits": {0: "batch_size"},
        },
        dynamo         = False,              # TorchScript path (UE NNI compatible)
    )
    print(f"[ONNX] Model exported → '{path}'")

    # ── Export Vocabulary & Config as JSON ────────────────────────────────
    # BUG FIX: json.dump() silently converts integer dict keys to strings
    # ("0", "1"...) regardless of their Python type.  We pre-convert them to
    # strings here so the schema is explicit and your C++ JSON parser won't
    # receive unexpected types.
    # e.g.  {0: "intent_buy"}  →  {"0": "intent_buy"}
    intent_labels_str_keys = {str(k): v for k, v in LABEL_TO_INTENT.items()}

    config = {
        "max_sequence_length": max_len,
        "pad_token":           Vocabulary.PAD_TOKEN,
        "unk_token":           Vocabulary.UNK_TOKEN,
        "pad_index":           0,
        "unk_index":           1,
        "num_intents":         len(INTENT_LABELS),
        "intent_labels":       intent_labels_str_keys,  # {"0": "intent_buy", ...}
        "vocabulary":          vocab.word2idx,           # {"<PAD>": 0, "buy": 4, ...}
    }

    config_path = path.replace(".onnx", "_config.json")
    with open(config_path, "w", encoding="utf-8") as f:
        json.dump(config, f, indent=2)
    print(f"[ONNX] Vocab + config exported → '{config_path}'")

    return path, config_path


