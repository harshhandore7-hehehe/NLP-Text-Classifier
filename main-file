def main():
    # ── Hyperparameters ───────────────────────────────────────────────────
    # These are the "tuning knobs" of the model. Think of them like
    # settings on a mixing board — changing them affects model quality.
    MAX_SEQ_LEN   = 20    # Maximum words per player sentence
    EMBEDDING_DIM = 64    # How many floats represent each word
    HIDDEN_DIM    = 128   # Internal LSTM memory size
    BATCH_SIZE    = 16    # How many training examples to process at once
    EPOCHS        = 200   # How many times to cycle through all data
    LEARNING_RATE = 0.001 # How big each gradient step is
    NUM_INTENTS   = len(INTENT_LABELS)  # 5

    print("\n" + "="*60)
    print("  MAGIC VENDOR NPC — INTENT CLASSIFIER")
    print("  Building the brain for your Unreal Engine NPC...")
    print("="*60)

    # ── Step 1: Tokenize all training sentences ───────────────────────────
    print("\n[Step 1] Tokenizing training data...")
    all_tokens = [tokenize(text) for text, _ in RAW_DATA]

    # ── Step 2: Build vocabulary ──────────────────────────────────────────
    print("[Step 2] Building vocabulary...")
    vocab = Vocabulary()
    vocab.build(all_tokens, min_freq=1)

    # ── Step 3: Create Dataset and DataLoader ─────────────────────────────
    print("[Step 3] Preparing dataset and dataloader...")
    dataset    = IntentDataset(RAW_DATA, vocab, MAX_SEQ_LEN)
    dataloader = DataLoader(dataset, batch_size=BATCH_SIZE, shuffle=True)
    print(f"         Dataset: {len(dataset)} samples across "
          f"{NUM_INTENTS} intents")

    # ── Step 4: Build the model ───────────────────────────────────────────
    print("[Step 4] Constructing neural network...")
    model = MagicVendorIntentClassifier(
        vocab_size    = len(vocab),
        embedding_dim = EMBEDDING_DIM,
        hidden_dim    = HIDDEN_DIM,
        output_dim    = NUM_INTENTS,
        pad_idx       = 0,
        dropout_rate  = 0.4,
    )

    # Count and display total trainable parameters
    total_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"         Total trainable parameters: {total_params:,}")
    print(f"         Architecture: Embedding({len(vocab)}x{EMBEDDING_DIM}) → "
          f"BiLSTM({HIDDEN_DIM}x2) → FC({HIDDEN_DIM}) → FC({NUM_INTENTS})")

    # ── Step 5: Train ─────────────────────────────────────────────────────
    print("[Step 5] Training...")
    model = train_model(model, dataloader, epochs=EPOCHS, lr=LEARNING_RATE)

    # ── Step 6: Test with example player inputs ───────────────────────────
    test_inputs = [
        "Are you trying to rob me blind?",           # expect: intent_haggle
        "I want to buy a scroll of fireball",         # expect: intent_buy
        "Do you have scrolls for sale",               # expect: intent_buy
        "Take these old potions I don't need them",   # expect: intent_sell
        "Where did this ancient tome come from",      # expect: intent_lore
        "Is this scripture actually authentic",       # expect: intent_lore
        "What is the weather like today",             # expect: intent_other
        "Five hundred gold you must be joking",       # expect: intent_haggle
        "I'll sell you my enchanted ring",            # expect: intent_sell
        "qwerty asdf zxcv",                           # expect: intent_other
    ]

    print("=" * 60)
    print("  INFERENCE TEST — Predicting Player Intent")
    print("=" * 60 + "\n")

    for player_input in test_inputs:
        result = predict_intent(player_input, model, vocab, MAX_SEQ_LEN)
        print_prediction(result)

    # ── Step 7: Export to ONNX for Unreal Engine ─────────────────────────
    print("=" * 60)
    print("  EXPORTING BRAIN FOR UNREAL ENGINE NNI")
    print("=" * 60 + "\n")

    # Wrapped in try/except so a failed export NEVER destroys the trained model.
    # If this block errors, your training results are still safe in `model`.
    try:
        onnx_path, config_path = export_to_onnx(
            model,
            vocab,
            MAX_SEQ_LEN,
            path="magic_vendor_brain.onnx",
        )
        export_success = True
    except Exception as e:
        print(f"[ONNX] Export failed: {type(e).__name__}: {e}")
        print("[ONNX] Your trained model is still available in the 'model' variable.")
        print("[ONNX] Try: !pip install onnx  then re-run only the export cell.")
        export_success = False

    if export_success:
        print(f"""
